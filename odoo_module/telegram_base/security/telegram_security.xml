<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module category -->
        <record id="module_category_telegram" model="ir.module.category">
            <field name="name">Telegram</field>
            <field name="sequence">100</field>
        </record>

        <!-- Groups (hierarchical: admin > dev > freela) -->
        <record id="group_telegram_freela" model="res.groups">
            <field name="name">Freela</field>
            <field name="category_id" ref="module_category_telegram"/>
            <field name="comment">Access to assigned tasks only via Telegram bot.</field>
        </record>

        <record id="group_telegram_dev" model="res.groups">
            <field name="name">Dev</field>
            <field name="category_id" ref="module_category_telegram"/>
            <field name="implied_ids" eval="[(4, ref('group_telegram_freela'))]"/>
            <field name="comment">Access to projects, tasks, hours, and code status via Telegram bot.</field>
        </record>

        <record id="group_telegram_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_category_telegram"/>
            <field name="implied_ids" eval="[(4, ref('group_telegram_dev'))]"/>
            <field name="comment">Full access including infrastructure, finances, and approvals via Telegram bot.</field>
        </record>
    </data>
</odoo>
