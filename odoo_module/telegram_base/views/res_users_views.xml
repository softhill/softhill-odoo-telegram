<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_telegram" model="ir.ui.view">
        <field name="name">res.users.form.telegram</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Telegram" name="telegram">
                    <group>
                        <group string="Telegram Integration">
                            <field name="telegram_id"/>
                            <field name="telegram_api_token"/>
                        </group>
                        <group string="Actions">
                            <button name="action_generate_api_token"
                                    type="object"
                                    string="Generate API Token"
                                    class="btn-primary"
                                    groups="telegram_base.group_telegram_admin"/>
                            <button name="action_revoke_api_token"
                                    type="object"
                                    string="Revoke Token"
                                    class="btn-secondary"
                                    groups="telegram_base.group_telegram_admin"
                                    confirm="Are you sure you want to revoke this API token?"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
