<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telegram_tool_list" model="ir.ui.view">
        <field name="name">telegram.tool.list</field>
        <field name="model">telegram.tool</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="display_name_field" string="Label"/>
                <field name="category" widget="badge"/>
                <field name="allowed_profile_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
                <field name="permission_level" optional="hide"/>
                <field name="requires_confirmation"/>
                <field name="active"/>
                <field name="usage_count" string="Uses (30d)"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_tool_form" model="ir.ui.view">
        <field name="name">telegram.tool.form</field>
        <field name="model">telegram.tool</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name_field" placeholder="Display name"/></h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="name"/>
                            <field name="method_name"/>
                            <field name="category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Permissions">
                            <field name="allowed_profile_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="permission_level"
                                   invisible="allowed_profile_ids"/>
                            <field name="requires_confirmation"/>
                            <field name="usage_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Input Schema (JSON)">
                            <field name="input_schema" nolabel="1" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telegram_tool_search" model="ir.ui.view">
        <field name="name">telegram.tool.search</field>
        <field name="model">telegram.tool</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="allowed_profile_ids"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="read" string="Read" domain="[('category','=','read')]"/>
                <filter name="write" string="Write" domain="[('category','=','write')]"/>
                <filter name="github" string="GitHub" domain="[('category','=','github')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                    <filter name="group_perm" string="Permission" context="{'group_by': 'permission_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_telegram_tool" model="ir.actions.act_window">
        <field name="name">Tools</field>
        <field name="res_model">telegram.tool</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_telegram_tools" name="Tools"
              parent="menu_telegram_config"
              action="action_telegram_tool"
              sequence="30"/>

    <!-- Pending Actions -->
    <record id="view_telegram_pending_action_list" model="ir.ui.view">
        <field name="name">telegram.pending_action.list</field>
        <field name="model">telegram.pending_action</field>
        <field name="arch" type="xml">
            <list create="0"
                  decoration-warning="status == 'pending'"
                  decoration-success="status == 'confirmed'"
                  decoration-muted="status in ('cancelled', 'expired')">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="summary"/>
                <field name="status" widget="badge"/>
                <field name="expires_at"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_pending_action_form" model="ir.ui.view">
        <field name="name">telegram.pending_action.form</field>
        <field name="model">telegram.pending_action</field>
        <field name="arch" type="xml">
            <form create="0">
                <header>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="action_type"/>
                            <field name="model_name"/>
                            <field name="record_id"/>
                        </group>
                        <group>
                            <field name="chat_id"/>
                            <field name="expires_at"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Action Data">
                            <field name="action_data" nolabel="1" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Result" invisible="not result">
                            <field name="result" nolabel="1" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telegram_pending_action" model="ir.actions.act_window">
        <field name="name">Pending Actions</field>
        <field name="res_model">telegram.pending_action</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_telegram_pending_actions" name="Pending Actions"
              parent="menu_telegram_config"
              action="action_telegram_pending_action"
              sequence="40"/>

</odoo>
