<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- READ TOOLS -->
    <record id="tool_search_odoo" model="telegram.tool">
        <field name="name">search_odoo</field>
        <field name="display_name_field">Search Records</field>
        <field name="description">Search records in any Odoo model. Common models: sale.order, purchase.order, res.partner, product.product, stock.picking, account.move, project.task, account.analytic.line (timesheets). Domain uses Odoo format: [('field','operator','value')].</field>
        <field name="category">read</field>
        <field name="method_name">_tool_search_odoo</field>
        <field name="permission_level">freela</field>
        <field name="sequence">1</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string", "description": "Technical model name"},
        "domain": {"type": "array", "description": "Odoo domain filters"},
        "fields": {"type": "array", "items": {"type": "string"}, "description": "Fields to return"},
        "limit": {"type": "integer", "description": "Limit (default: 10)"},
        "order": {"type": "string", "description": "Sort order"}
    },
    "required": ["model"]
}</field>
    </record>

    <record id="tool_count_odoo" model="telegram.tool">
        <field name="name">count_odoo</field>
        <field name="display_name_field">Count Records</field>
        <field name="description">Count records in an Odoo model matching a domain.</field>
        <field name="category">read</field>
        <field name="method_name">_tool_count_odoo</field>
        <field name="permission_level">freela</field>
        <field name="sequence">2</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "domain": {"type": "array"}
    },
    "required": ["model"]
}</field>
    </record>

    <record id="tool_read_record" model="telegram.tool">
        <field name="name">read_record</field>
        <field name="display_name_field">Read Record</field>
        <field name="description">Read a single record by ID.</field>
        <field name="category">read</field>
        <field name="method_name">_tool_read_record</field>
        <field name="permission_level">freela</field>
        <field name="sequence">3</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "record_id": {"type": "integer"},
        "fields": {"type": "array", "items": {"type": "string"}}
    },
    "required": ["model", "record_id"]
}</field>
    </record>

    <record id="tool_get_fields" model="telegram.tool">
        <field name="name">get_fields</field>
        <field name="display_name_field">Model Fields</field>
        <field name="description">Discover fields of an Odoo model. Use before search_odoo if you don't know the field names.</field>
        <field name="category">read</field>
        <field name="method_name">_tool_get_fields</field>
        <field name="permission_level">freela</field>
        <field name="sequence">4</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"}
    },
    "required": ["model"]
}</field>
    </record>

    <!-- WRITE TOOLS -->
    <record id="tool_create_record" model="telegram.tool">
        <field name="name">create_record</field>
        <field name="display_name_field">Create Record</field>
        <field name="description">Create a record in any Odoo model. For Many2one fields, use the numeric ID. For One2many fields, use format [[0, 0, {vals}]]. Financial models (sale.order, purchase.order, account.move) require confirmation.</field>
        <field name="category">write</field>
        <field name="method_name">_tool_create_record</field>
        <field name="permission_level">dev</field>
        <field name="requires_confirmation" eval="True"/>
        <field name="sequence">10</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string", "description": "Technical model name"},
        "values": {"type": "object", "description": "Field values dictionary"}
    },
    "required": ["model", "values"]
}</field>
    </record>

    <record id="tool_update_record" model="telegram.tool">
        <field name="name">update_record</field>
        <field name="display_name_field">Update Record</field>
        <field name="description">Update fields on an existing record. For Many2one fields, use the numeric ID. For Many2many fields, use [[6, 0, [ids]]] to replace, [[4, id]] to add.</field>
        <field name="category">write</field>
        <field name="method_name">_tool_update_record</field>
        <field name="permission_level">dev</field>
        <field name="sequence">11</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "record_id": {"type": "integer"},
        "values": {"type": "object"}
    },
    "required": ["model", "record_id", "values"]
}</field>
    </record>

    <record id="tool_execute_action" model="telegram.tool">
        <field name="name">execute_action</field>
        <field name="display_name_field">Execute Action</field>
        <field name="description">Execute an action/method on an Odoo record. Common actions: action_confirm (confirm order), action_done (complete), action_cancel (cancel), button_validate (validate picking), action_post (post invoice). Always requires confirmation.</field>
        <field name="category">write</field>
        <field name="method_name">_tool_execute_action</field>
        <field name="permission_level">dev</field>
        <field name="requires_confirmation" eval="True"/>
        <field name="sequence">12</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "record_id": {"type": "integer"},
        "method": {"type": "string", "description": "Method name to execute"}
    },
    "required": ["model", "record_id", "method"]
}</field>
    </record>

    <record id="tool_delete_record" model="telegram.tool">
        <field name="name">delete_record</field>
        <field name="display_name_field">Delete Record</field>
        <field name="description">Delete a record. Always requires confirmation.</field>
        <field name="category">write</field>
        <field name="method_name">_tool_delete_record</field>
        <field name="permission_level">admin</field>
        <field name="requires_confirmation" eval="True"/>
        <field name="sequence">13</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "record_id": {"type": "integer"}
    },
    "required": ["model", "record_id"]
}</field>
    </record>

    <record id="tool_post_message" model="telegram.tool">
        <field name="name">post_message</field>
        <field name="display_name_field">Post Message</field>
        <field name="description">Post a message on the chatter of an Odoo record. Useful for internal communication, notes and notifications.</field>
        <field name="category">write</field>
        <field name="method_name">_tool_post_message</field>
        <field name="permission_level">dev</field>
        <field name="sequence">14</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "model": {"type": "string"},
        "record_id": {"type": "integer"},
        "body": {"type": "string", "description": "Message body"},
        "message_type": {"type": "string", "enum": ["comment", "note"], "description": "comment = notify followers, note = internal note"}
    },
    "required": ["model", "record_id", "body"]
}</field>
    </record>

    <!-- GITHUB TOOLS -->
    <record id="tool_github_list_repos" model="telegram.tool">
        <field name="name">github_list_repos</field>
        <field name="display_name_field">List Repos</field>
        <field name="description">List repositories from a GitHub organization.</field>
        <field name="category">github</field>
        <field name="method_name">_tool_github_list_repos</field>
        <field name="permission_level">dev</field>
        <field name="sequence">20</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "org": {"type": "string", "description": "Organization (default: configured in system)"},
        "type": {"type": "string", "enum": ["all", "public", "private"]}
    }
}</field>
    </record>

    <record id="tool_github_read_file" model="telegram.tool">
        <field name="name">github_read_file</field>
        <field name="display_name_field">Read File</field>
        <field name="description">Read file contents from a GitHub repository.</field>
        <field name="category">github</field>
        <field name="method_name">_tool_github_read_file</field>
        <field name="permission_level">dev</field>
        <field name="sequence">21</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "repo": {"type": "string", "description": "Repo name (org/repo or just repo)"},
        "path": {"type": "string", "description": "File path in the repo"},
        "ref": {"type": "string", "description": "Branch or commit (default: main)"}
    },
    "required": ["repo", "path"]
}</field>
    </record>

    <record id="tool_github_search_code" model="telegram.tool">
        <field name="name">github_search_code</field>
        <field name="display_name_field">Search Code</field>
        <field name="description">Search code across GitHub repositories in the organization.</field>
        <field name="category">github</field>
        <field name="method_name">_tool_github_search_code</field>
        <field name="permission_level">dev</field>
        <field name="sequence">22</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "query": {"type": "string", "description": "Text to search in code"},
        "repo": {"type": "string", "description": "Filter by specific repo"},
        "extension": {"type": "string", "description": "Filter by extension (py, js, xml)"}
    },
    "required": ["query"]
}</field>
    </record>

    <record id="tool_github_list_commits" model="telegram.tool">
        <field name="name">github_list_commits</field>
        <field name="display_name_field">List Commits</field>
        <field name="description">List recent commits from a repository.</field>
        <field name="category">github</field>
        <field name="method_name">_tool_github_list_commits</field>
        <field name="permission_level">dev</field>
        <field name="sequence">23</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "repo": {"type": "string"},
        "branch": {"type": "string", "description": "Branch (default: main)"},
        "limit": {"type": "integer", "description": "Count (default: 10)"}
    },
    "required": ["repo"]
}</field>
    </record>

    <record id="tool_github_list_prs" model="telegram.tool">
        <field name="name">github_list_prs</field>
        <field name="display_name_field">List PRs</field>
        <field name="description">List pull requests from a repository.</field>
        <field name="category">github</field>
        <field name="method_name">_tool_github_list_prs</field>
        <field name="permission_level">dev</field>
        <field name="sequence">24</field>
        <field name="input_schema">{
    "type": "object",
    "properties": {
        "repo": {"type": "string"},
        "state": {"type": "string", "enum": ["open", "closed", "all"], "description": "State (default: open)"}
    },
    "required": ["repo"]
}</field>
    </record>

</odoo>
