<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telegram_user_profile_list" model="ir.ui.view">
        <field name="name">telegram.user.profile.list</field>
        <field name="model">telegram.user.profile</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="group_id"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_user_profile_form" model="ir.ui.view">
        <field name="name">telegram.user.profile.form</field>
        <field name="model">telegram.user.profile</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Profile name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="group_id"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telegram_user_profile_search" model="ir.ui.view">
        <field name="name">telegram.user.profile.search</field>
        <field name="model">telegram.user.profile</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="group_id"/>
            </search>
        </field>
    </record>

    <record id="action_telegram_user_profile" model="ir.actions.act_window">
        <field name="name">User Profiles</field>
        <field name="res_model">telegram.user.profile</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_telegram_user_profiles" name="User Profiles"
              parent="menu_telegram_root"
              action="action_telegram_user_profile"
              sequence="20"/>

</odoo>
