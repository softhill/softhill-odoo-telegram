<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_telegram" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.telegram</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="after">
                <app string="Telegram" name="telegram_base">
                    <block title="Telegram Bot">
                        <setting string="Bot Name" help="Display name used in bot greeting messages">
                            <field name="telegram_bot_display_name" placeholder="AI Assistant"/>
                        </setting>
                        <setting string="Bot Token" help="Token from @BotFather">
                            <field name="telegram_bot_token" password="True"/>
                        </setting>
                        <setting string="Webhook Secret" help="Secret to validate incoming webhooks">
                            <field name="telegram_webhook_secret"/>
                        </setting>
                    </block>
                    <block title="Artificial Intelligence">
                        <setting string="Provider" help="AI provider for the chat">
                            <field name="telegram_ai_provider" widget="radio"/>
                        </setting>
                        <setting string="API Key">
                            <field name="telegram_ai_api_key" password="True"/>
                        </setting>
                        <setting string="Base URL">
                            <field name="telegram_ai_base_url"/>
                        </setting>
                        <setting string="Model">
                            <field name="telegram_ai_model"/>
                        </setting>
                    </block>
                    <block title="GitHub">
                        <setting string="GitHub Token" help="Token to access repositories (scope: repo:read)">
                            <field name="telegram_github_token" password="True"/>
                        </setting>
                        <setting string="Organization" help="Default GitHub organization">
                            <field name="telegram_github_org"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
