<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_telegram" model="ir.ui.view">
        <field name="name">res.users.form.telegram</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Telegram" name="telegram">
                    <group>
                        <group string="Telegram Account">
                            <field name="telegram_id" readonly="1"/>
                            <field name="telegram_profile_id"/>
                            <button name="action_generate_telegram_link_code"
                                    string="Generate Link Code" type="object"
                                    class="btn-primary"
                                    invisible="telegram_id"
                                    help="Generate a 6-digit code, then use /link &lt;code&gt; in Telegram"/>
                            <button name="action_unlink_telegram"
                                    string="Unlink Telegram" type="object"
                                    class="btn-danger"
                                    invisible="not telegram_id"
                                    confirm="This will disconnect the Telegram account. The user will need to re-link."/>
                        </group>
                        <group string="API Token"
                               groups="telegram_base.group_telegram_admin">
                            <field name="telegram_api_token"/>
                            <button name="action_generate_telegram_token"
                                    string="Generate Token" type="object"
                                    class="btn-primary"
                                    invisible="telegram_api_token"/>
                            <button name="action_revoke_telegram_token"
                                    string="Revoke Token" type="object"
                                    class="btn-danger"
                                    invisible="not telegram_api_token"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
